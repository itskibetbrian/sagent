{
  "expo": {
    "name": "Sagent",
    "slug": "sagent",
    "version": "1.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#EDE9F6",
    "scheme": "sagent",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sagent.app",
      "buildNumber": "1",
