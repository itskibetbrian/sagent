        "NSPhotoLibraryUsageDescription": "Not used.",
        "UIBackgroundModes": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0F13"
      },
      "backgroundColor": "#EDE9F6",
      "package": "com.sagent.app",
      "versionCode": 2,
      "permissions": []
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": []
  }
